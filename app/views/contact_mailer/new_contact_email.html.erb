<!DOCTYPE html>
<html>
  <head>
    <meta content='text/html; charset=UTF-8' http-equiv='Content-Type' />
    <style>
      body {
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
        background-color: #fbf9f5; /* brand-cream */
        color: #1e1b18; /* brand-dark */
        margin: 0;
        padding: 20px;
      }
      .wrapper {
        max-width: 600px;
        margin: 0 auto;
        background: #ffffff;
        border: 1px border #dfd5c6; /* brand-tan */
        border-radius: 6px;
        overflow: hidden;
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
      }
      .header {
        background-color: #1e1b18; /* brand-dark */
        padding: 30px;
        text-align: center;
      }
      .header h1 {
        color: #fbf9f5;
        margin: 0;
        font-size: 24px;
        letter-spacing: 1px;
      }
      .content {
        padding: 40px 30px;
      }
      .field-label {
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #5f6b5e; /* brand-sage */
        font-weight: bold;
        margin-bottom: 4px;
      }
      .field-value {
        font-size: 16px;
        margin-bottom: 24px;
        color: #1e1b18;
      }
      .message-box {
        background-color: #fbf9f5;
        border-left: 4px solid #a65b32; /* brand-clay */
        padding: 15px;
        font-style: italic;
        white-space: pre-wrap;
      }
      .footer {
        background-color: #dfd5c6; /* brand-tan */
        padding: 15px;
        text-align: center;
        font-size: 11px;
        color: #5f6b5e;
      }
    </style>
  </head>
  <body>
    <div class="wrapper">
      <div class="header">
        <h1>DD Cattle Company</h1>
      </div>

      <div class="content">
        <div class="field-label">From</div>
        <div class="field-value"><strong><%= @name %></strong> (<%= @email %>)</div>

        <div class="field-label">Received Date</div>
        <div class="field-value"><%= Time.current.strftime("%B %d, %Y at %I:%M %p") %></div>

        <div class="field-label">Message</div>
        <div class="message-box">
          <%= @message %>
        </div>
      </div>

      <div class="footer">
        This notification was automatically generated by your portfolio application.
      </div>
    </div>
  </body>
</html>